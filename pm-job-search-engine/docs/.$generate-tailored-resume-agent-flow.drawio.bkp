        <mxCell id="title" value="&lt;b&gt;Generate Tailored Resume — AI Agent Sub-Agent Decomposition&lt;/b&gt;" style="text;html=1;fontSize=22;fontFamily=Inter;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1e3a5f;" vertex="1" parent="1">
