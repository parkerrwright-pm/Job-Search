        <mxCell id="orchestrator" value="&lt;b&gt;PRIMARY ORCHESTRATOR AGENT&lt;/b&gt;&lt;br&gt;Coordinates all sub-agents, manages state &amp; DB persistence" style="swimlane;startSize=40;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#1e3a5f;strokeWidth=2;fontSize=13;fontFamily=Inter;fontColor=#1e3a5f;rounded=1;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="170" width="1270" height="1700" as="geometry" />
        </mxCell>

        <!-- ──────────────────────────────────────────────────── -->
        <!-- SUB-AGENT 1: Input Resolution Agent                  -->
        <!-- ──────────────────────────────────────────────────── -->
        <mxCell id="sa1_box" value="" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#4a86c8;strokeWidth=1.5;rounded=1;arcSize=8;fontSize=11;fontFamily=Inter;fontStyle=1;fontColor=#1e3a5f;" vertex="1" parent="orchestrator">
