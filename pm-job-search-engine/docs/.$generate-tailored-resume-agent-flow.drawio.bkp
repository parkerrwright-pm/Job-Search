        <mxCell id="sa2_parse_jd" value="parseJobDescriptionStructure()&lt;br&gt;&lt;i&gt;→ requiredSkills[],&lt;br&gt;preferredSkills[],&lt;br&gt;seniorityLevel, experienceYears,&lt;br&gt;domainKeywords[]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4caf50;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa2_box">
          <mxGeometry x="210" y="40" width="175" height="100" as="geometry" />
