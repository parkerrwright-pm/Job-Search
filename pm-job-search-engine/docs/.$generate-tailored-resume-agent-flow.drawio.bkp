        <mxCell id="sa1_fetch_job" value="Fetch Job Record&lt;br&gt;&lt;i&gt;(title, company, JD text, URL)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4a86c8;fontSize=11;fontFamily=Inter;" vertex="1" parent="sa1_box">
