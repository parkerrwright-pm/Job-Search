        <mxCell id="sa5_e3" value="FAIL (iter &lt; max)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#f9a825;fontSize=10;fontFamily=Inter;fontStyle=1;" edge="1" parent="sa5_box" source="sa5_check" target="sa5_refine">
