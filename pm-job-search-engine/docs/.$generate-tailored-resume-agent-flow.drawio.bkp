        <mxCell id="sa5_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#4caf50;fontSize=10;fontFamily=Inter;" edge="1" parent="sa5_box" source="sa5_persist" target="sa5_workflow_meta">
          <mxGeometry relative="1" as="geometry" />
