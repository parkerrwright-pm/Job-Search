        <!-- Gate arrows -->
        <mxCell id="sa5_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#e53935;fontSize=10;fontFamily=Inter;" edge="1" parent="sa5_box" source="sa5_extract" target="sa5_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa5_e2" value="PASS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;strokeColor=#4caf50;fontSize=10;fontFamily=Inter;fontStyle=1;" edge="1" parent="sa5_box" source="sa5_check" target="sa5_pass">
          <mxGeometry relative="1" as="geometry" />
