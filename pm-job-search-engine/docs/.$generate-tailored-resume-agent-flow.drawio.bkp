          <mxGeometry x="120" y="195" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- Output summary -->
        <mxCell id="sa4_output" value="&lt;b&gt;OUTPUT:&lt;/b&gt; 18-section analysis object (~50-100KB JSON)&lt;br&gt;&lt;i&gt;ATS scores, bullet rewrites, missing keywords, skills, summary options,&lt;br&gt;company strategy, interview prep, job match summary&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#7e57c2;strokeWidth=1.5;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa4_box">
          <mxGeometry x="340" y="185" width="520" height="60" as="geometry" />
        </mxCell>

        <!-- ──────────────────────────────────────────────────── -->
        <!-- SUB-AGENT 5: Quality Gate Evaluator                  -->
        <!-- ──────────────────────────────────────────────────── -->
        <mxCell id="sa5_box" value="" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;strokeWidth=1.5;rounded=1;arcSize=8;fontSize=11;fontFamily=Inter;fontStyle=1;fontColor=#b71c1c;" vertex="1" parent="orchestrator">
          <mxGeometry x="30" y="840" width="1210" height="220" as="geometry" />
        </mxCell>
        <mxCell id="sa5_label" value="&lt;b&gt;⑤ Quality Gate Evaluator Agent&lt;/b&gt;  —  Iterates up to 3 times until scores pass" style="text;html=1;fontSize=14;fontFamily=Inter;fontColor=#b71c1c;fillColor=none;strokeColor=none;align=left;" vertex="1" parent="sa5_box">
          <mxGeometry x="10" y="5" width="600" height="25" as="geometry" />
        </mxCell>
        <mxCell id="sa5_extract" value="Extract Scores&lt;br&gt;&lt;i&gt;atsScore, aiReviewerScore&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e53935;fontSize=11;fontFamily=Inter;" vertex="1" parent="sa5_box">
          <mxGeometry x="20" y="40" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sa5_check" value="&lt;b&gt;Gate Check&lt;/b&gt;&lt;br&gt;&lt;i&gt;atsScore ≥ minAts&lt;br&gt;AND&lt;br&gt;aiReviewer ≥ minReviewer&lt;/i&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e53935;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa5_box">
          <mxGeometry x="240" y="30" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sa5_pass" value="✅ PASS&lt;br&gt;&lt;i&gt;Use best analysis&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#4caf50;fontSize=11;fontFamily=Inter;fontStyle=1;" vertex="1" parent="sa5_box">
          <mxGeometry x="480" y="35" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sa5_refine" value="🔄 REFINE&lt;br&gt;&lt;i&gt;buildRefinementContext()&lt;br&gt;+ ATS rules addendum&lt;br&gt;→ Re-run Analysis Agent&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa5_box">
          <mxGeometry x="480" y="105" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sa5_track" value="Track Best Score&lt;br&gt;&lt;i&gt;scoreHistory[],&lt;br&gt;bestAnalysis,&lt;br&gt;baselineAtsScore&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e53935;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa5_box">
          <mxGeometry x="20" y="115" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="sa5_persist" value="Persist to DB&lt;br&gt;&lt;i&gt;jobAnalysis.upsert()&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#e53935;fontSize=11;fontFamily=Inter;" vertex="1" parent="sa5_box">
          <mxGeometry x="730" y="35" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sa5_workflow_meta" value="&lt;b&gt;Workflow Metadata&lt;/b&gt;&lt;br&gt;&lt;i&gt;iterationsRun, passed, baselineAtsScore,&lt;br&gt;bestIterationAtsScore, scoreHistory[]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e53935;strokeWidth=1.5;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa5_box">
          <mxGeometry x="930" y="35" width="250" height="60" as="geometry" />
