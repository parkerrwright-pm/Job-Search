        <mxCell id="sa3_url_detect" value="detectAtsFromUrl()&lt;br&gt;&lt;i&gt;URL pattern matching&lt;br&gt;(14 ATS providers)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#f57c00;fontSize=11;fontFamily=Inter;" vertex="1" parent="sa3_box">
