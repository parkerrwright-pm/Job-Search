        <mxCell id="sa2_parse_resume" value="parseResumeStructureEnhanced()&lt;br&gt;&lt;i&gt;→ name, contact, summary,&lt;br&gt;skills[], workEntries[{title,&lt;br&gt;company, dates, bullets}],&lt;br&gt;education, certifications&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4caf50;fontSize=10;fontFamily=Inter;" vertex="1" parent="sa2_box">
