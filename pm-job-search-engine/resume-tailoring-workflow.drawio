    <mxCell id="leg4" value="Content tailoring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8a000;fontColor=#1a1a00;strokeColor=#9a7a00;fontSize=10;" vertex="1" parent="1">
