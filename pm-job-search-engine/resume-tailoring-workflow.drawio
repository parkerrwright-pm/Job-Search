    <mxCell id="legend_bg" value="LEGEND" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#444444;fontSize=11;fontStyle=1;verticalAlign=top;align=center;spacingTop=8;" vertex="1" parent="1">
