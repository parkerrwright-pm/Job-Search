    <mxCell id="ec_rend_tmpl" value="loads" style="dashed=1;endArrow=open;endFill=0;strokeColor=#888888;fontSize=9;fontStyle=2;" edge="1" source="n_renderer" target="sa_templates" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Word/PDF use Export Engine -->
    <mxCell id="ec_word_exp" value="via" style="dashed=1;endArrow=open;endFill=0;strokeColor=#888888;fontSize=9;fontStyle=2;" edge="1" source="n_word" target="sa_export" parent="1">
